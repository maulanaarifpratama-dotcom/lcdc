{
  "name": "little-champ-daycare-web-v5",
  "private": true,
  "version": "5.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings=0",
    "validate": "node scripts/validate-content.mjs",
    "sitemap": "node scripts/generate-sitemap.mjs",
    "predeploy": "npm run sitemap && npm run validate && npm run build && npm run lint",
    "prepare": "husky"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.18.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "globals": "^16.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "prettier": "^3.5.3",
    "typescript-eslint": "^8.34.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,md}": [
      "prettier --write"
    ]
  }
}
